{
  "test_scenarios": [
    {
      "name": "health_check",
      "description": "Проверка здоровья сервиса",
      "endpoint": "/health",
      "method": "GET",
      "expected_status": 200,
      "expected_response": {
        "status": "ok"
      }
    },
    {
      "name": "predict_good_wine",
      "description": "Предсказание для хорошего вина",
      "endpoint": "/predict",
      "method": "POST",
      "input": {
        "fixed_acidity": 8.0,
        "volatile_acidity": 0.2,
        "citric_acid": 0.4,
        "residual_sugar": 5.0,
        "chlorides": 0.05,
        "free_sulfur_dioxide": 30,
        "total_sulfur_dioxide": 100,
        "density": 0.995,
        "ph": 3.3,
        "sulphates": 0.5,
        "alcohol": 11.0
      },
      "expected_status": 200,
      "expected_fields": ["quality", "quality_class", "probability"]
    },
    {
      "name": "predict_bad_wine",
      "description": "Предсказание для плохого вина",
      "endpoint": "/predict",
      "method": "POST",
      "input": {
        "fixed_acidity": 6.0,
        "volatile_acidity": 0.5,
        "citric_acid": 0.1,
        "residual_sugar": 10.0,
        "chlorides": 0.08,
        "free_sulfur_dioxide": 50,
        "total_sulfur_dioxide": 200,
        "density": 1.002,
        "ph": 3.0,
        "sulphates": 0.3,
        "alcohol": 8.0
      },
      "expected_status": 200,
      "expected_fields": ["quality", "quality_class", "probability"]
    },
    {
      "name": "predict_missing_field",
      "description": "Ошибка при отсутствии обязательного поля",
      "endpoint": "/predict",
      "method": "POST",
      "input": {
        "fixed_acidity": 7.0
      },
      "expected_status": 422
    },
    {
      "name": "get_features",
      "description": "Получение списка признаков",
      "endpoint": "/features",
      "method": "GET",
      "expected_status": 200
    }
  ]
}